{
  "license": "ISC",
  "scripts": {
    "dev:relayer": "npm run relayer",
    "dev:web": "npm run app",
    "relayer": "TS_NODE_TRANSPILE_ONLY=1 ts-node relayer/index.ts",
    "relayer:build": "tsc --noEmit",
    "relayer:deploy-check": "npm run relayer:build",
    "build:web": "npm --prefix app run build",
    "check": "npm run relayer:build && npm run build:web",
    "bet": "TS_NODE_TRANSPILE_ONLY=1 ts-node relayer/sports-bet.ts",
    "discord:register": "TS_NODE_TRANSPILE_ONLY=1 ts-node relayer/register-commands.ts",
    "app": "npm --prefix app run dev",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "mongodb": "^7.3.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^24.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
